# Flask / app
FLASK_APP=app.py
FLASK_ENV=development
ADMIN_USERNAME=change-me-admin-username
ADMIN_PASSWORD=change-me-strong-password
SECRET_KEY=change-me-long-random-secret

# Google Sheets (service account)
# Prefer an absolute path OUTSIDE the git working tree / secret store mount.
# Do not place google_credentials.json inside the repository.
# GOOGLE_CREDENTIALS_PATH=/secure/path/outside/repo/sa.json
GOOGLE_CREDENTIALS_PATH=

# Optional spreadsheet id override (if used by ops tooling)
# GOOGLE_SHEETS_ID=your-spreadsheet-id
